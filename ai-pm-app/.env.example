# AI PM App - 환경변수 예시
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요!

# ===== Google AI API =====
# https://aistudio.google.com/apikey 에서 발급
VITE_GOOGLE_API_KEY=your_google_ai_api_key_here

# ===== Supabase =====
# https://supabase.com 프로젝트 설정 > API에서 확인
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===== 관리자 설정 =====
# 관리자 이메일 (쉼표로 구분, 공백 없이)
VITE_ADMIN_EMAILS=admin@example.com,admin2@example.com
